# 部署环境变量示例（复制为 .env 后按需修改，.env 已被 .gitignore 忽略）
# 数据库使用 compose 自带的 MySQL 容器（服务名 db），无需在 .env 设置 DB_URL
# 容器 MySQL root 密码（默认 bookadmin123，建议生产环境改为强密码）
DB_PASSWORD=bookadmin123
# JWT 签名密钥：请用强随机值，例如  openssl rand -base64 48
JWT_SECRET=please-change-to-a-strong-random-value-generated-by-openssl-rand-base64-48
