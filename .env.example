# 部署环境变量示例（复制为 .env 后填入真实值，.env 已被 .gitignore 忽略）
# 阿里云 RDS MySQL 连接串：将 rm-xxxx.mysql.rds.aliyuncs.com 替换为你的 RDS 内网地址
DB_URL=jdbc:mysql://rm-xxxx.mysql.rds.aliyuncs.com:3306/book_admin?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
# RDS 高权限账号
DB_USERNAME=bookadmin
# RDS 账号密码
DB_PASSWORD=your_rds_password
# JWT 签名密钥：请用强随机值，例如  openssl rand -base64 48
JWT_SECRET=please-change-to-a-strong-random-value-generated-by-openssl-rand-base64-48
